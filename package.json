{
  "name": "snu-plp-hub",
  "version": "1.0.0",
  "description": "SNU Political Leaders Program Hub",
  "type": "module",
  "main": "server.js",
  "engines": {
    "node": ">=16.0.0"
  },
  "scripts": {
    "start": "node server.js",
    "server": "nodemon server.js",
    "client": "cd dist && npx serve -s",
    "dev": "nodemon server.js",
    "build": "mkdir -p dist && cp -r build/* dist/ || echo 'No build directory found'",
    "setup": "node setup.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.0",
    "mongoose": "^7.0.3",
    "concurrently": "^8.0.1",
    "serve": "^14.2.1"
  },
  "devDependencies": {
    "nodemon": "^2.0.22"
  }
}
